{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://docs.dsf.ink/sidebar.schema.json",
	"type": "object",
	"required": ["groups"],
	"properties": {
		"groups": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["labelJa", "labelEn"],
				"properties": {
					"labelJa": { "type": "string" },
					"labelEn": { "type": "string" },
					"autogenerate": {
						"type": ["object", "null"],
						"properties": {
							"directory": { "type": "string" }
						}
					},
					"items": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["slug", "labelJa", "labelEn"],
							"properties": {
								"slug": { "type": "string" },
								"labelJa": { "type": "string" },
								"labelEn": { "type": "string" }
							}
						}
					}
				}
			}
		}
	}
}
